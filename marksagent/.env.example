# MarksAgent - Discord Bot Configuration

# Discord Bot
DISCORD_TOKEN=your_discord_bot_token_here

# Bot Settings
COMMAND_PREFIX=!

# Budget (€ per day) - keep low since we prioritize free models
MAX_DAILY_SPEND=0.50

# === FREE MODELS (priority) ===

# Google Gemini (free tier - 15 RPM, 1500 RPM/day)
GEMINI_API_KEY=your_google_ai_studio_key

# MiniMax (free tier available)
MINIMAX_API_KEY=your_minimax_key

# Ollama (free local models - run `ollama serve`)
# Set URL to use local Gemma
OLLAMA_URL=http://localhost:11434

# === PAID FALLBACKS ===

# OpenRouter (has free credits tier)
OPENROUTER_API_KEY=your_openrouter_key

# === OPTIONAL SERVICES ===

# Supabase (for storing leads/conversations)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# GitHub (optional - for auto-updates)
GITHUB_TOKEN=your_github_token
GITHUB_REPO=username/repo